PORT=8080
# Local PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/music_shop
# Ubuntu Core / snap PostgreSQL example:
# DATABASE_URL=postgresql://postgres:postgres@localhost/music_shop?socket=/tmp

# Free remote PostgreSQL example:
# DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

SESSION_COOKIE_NAME=music_shop_session
SESSION_TTL_HOURS=168
SESSION_SECURE_COOKIE=false
CLIENT_ORIGIN=http://localhost:3000

# Cross-origin production cookies for free hosting on different domains
# SESSION_SECURE_COOKIE=true
# SESSION_COOKIE_SAME_SITE=none
# SESSION_COOKIE_DOMAIN=
# CLIENT_ORIGIN=https://your-frontend-domain.example
